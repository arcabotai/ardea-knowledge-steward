# Eve / Vercel AI Gateway model routing
# On Vercel, Gateway auth can use deployment OIDC automatically.
ARDEA_MODEL=openai/gpt-5.4-mini
ARDEA_AI_ENABLED=1
# ARDEA_DISABLE_AI=1

# Optional local / non-Vercel AI Gateway key. Do not commit real values.
# AI_GATEWAY_API_KEY=

# Optional direct provider keys. Prefer Vercel AI Gateway in production.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Future Farcaster/Hypersnap channel placeholders. Do not commit real values.
FARCASTER_BOT_FID=
FARCASTER_BOT_USERNAME=ardea
FARCASTER_WEBHOOK_SECRET=
FARCASTER_SIGNER_UUID=
SNAPCHAIN_HUB_URL=
COMPAT_FARCASTER_API_URL=
